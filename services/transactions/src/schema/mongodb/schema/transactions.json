{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "id": "http://Transactions",
    "title": "Transactions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "created": {
            "type": "number"
        },
        "transactionType": {
            "type": "string"
        },
        "total": {
            "type": "number"
        },
        "status": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "currency": {
            "type": "string"
        },
        "creditIdSource": {
            "type": "string"
        },
        "sourceAccount": {
            "type": "object",
            "title": "object",
            "required": [
                "walletId"
            ],
            "properties": {
                "accountNumber": {
                    "type": "string"
                },
                "walletId": {
                    "type": "string"
                }
            }
        },
        "destinationAccount": {
            "type": "object",
            "title": "object",
            "required": [
                "walletId"
            ],
            "properties": {
                "accountNumber": {
                    "type": "string"
                },
                "walletId": {
                    "type": "string"
                }
            }
        }
    }
}