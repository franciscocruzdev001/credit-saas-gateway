{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "id": "http://Payments",
    "title": "Payments",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "total": {
            "type": "number"
        },
        "paymentMethod": {
            "type": "string"
        },
        "creditId": {
            "type": "string"
        },
        "transactionId": {
            "type": "string"
        }
    },
    "required": [
        "creditId",
        "transactionId"
    ]
}