{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "id": "http://Credits",
    "title": "Credits",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "created": {
            "type": "number"
        },
        "startDateChargeConfig": {
            "type": "number",
            "description": "Se precarga con la fecha del ultimo reporte de cobro realizado al cobrador"
        },
        "admissionDate": {
            "type": "number"
        },
        "expirationDate": {
            "type": "number"
        },
        "creditAmount": {
            "type": "number"
        },
        "creditAmountWithMoratory": {
            "type": "number"
        },
        "fixedCharge": {
            "type": "number"
        },
        "status": {
            "type": "string"
        },
        "chargeRules": {
            "type": "object",
            "title": "object",
            "properties": {
                "chargeFrequency": {
                    "type": "string"
                },
                "chargePeriods": {
                    "type": "number"
                },
                "renovationPeriod": {
                    "type": "number"
                },
                "comissionRate": {
                    "type": "number"
                }
            }
        },
        "userId": {
            "type": "string"
        },
        "creditorCompanyId": {
            "type": "string"
        },
        "transactionId": {
            "type": "string"
        },
        "customerId": {
            "type": "string"
        }
    },
    "required": [
        "userId",
        "creditorCompanyId",
        "transactionId",
        "customerId"
    ]
}