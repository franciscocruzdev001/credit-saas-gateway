{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "id": "http://Users",
    "title": "Users",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "created": {
            "type": "number"
        },
        "userName": {
            "type": "string"
        },
        "email": {
            "type": "string"
        },
        "password": {
            "type": "string"
        },
        "roles": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "status": {
            "type": "string"
        },
        "contact": {
            "type": "object",
            "title": "contact",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "adress": {
                    "type": "string"
                },
                "phoneNumber": {
                    "type": "string"
                }
            }
        },
        "creditorCompanyId": {
            "type": "string"
        }
    },
    "required": [
        "userName",
        "email",
        "password",
        "roles",
        "creditorCompanyId"
    ]
}