# ==========================================
# TypeScript & Build Outputs
# ==========================================
# Ignore the JavaScript compilation directory (set via outDir in tsconfig.json)
dist/
build/
lib/
out/
# Ignore the JavaScript compilation directory (set via outDir in tsconfig.json) authorizer service
services/authorizer/dist/
services/authorizer/build/
services/authorizer/lib/
services/authorizer/out/
# Ignore the JavaScript compilation directory (set via outDir in tsconfig.json) credits service
services/credits/dist/
services/credits/build/
services/credits/lib/
services/credits/out/
# Ignore the JavaScript compilation directory (set via outDir in tsconfig.json) payments service
services/payments/dist/
services/payments/build/
services/payments/lib/
services/payments/out/
# Ignore the JavaScript compilation directory (set via outDir in tsconfig.json) transactions service
services/transactions/dist/
services/transactions/build/
services/transactions/lib/
services/transactions/out/

# TypeScript build info cache (speed up incremental compilation)
*.tsbuildinfo
# TypeScript build info cache (speed up incremental compilation) authorizer service
services/authorizer/*.tsbuildinfo
services/credits/*.tsbuildinfo
services/payments/*.tsbuildinfo
services/transactions/*.tsbuildinfo


# Prevent accidentally tracking raw JS files if compiled in-place
# (Uncomment the line below if you compile JS files directly next to TS files)
# src/**/*.js

